LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Local STT Settings
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
# Set to false on a fresh machine so the model is downloaded automatically
WHISPER_LOCAL_FILES_ONLY=true

# Transcript output directory (absolute path recommended for production)
# Defaults to <project_root>/transcripts/ if not set
TRANSCRIPTS_DIR=transcripts